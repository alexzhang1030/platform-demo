{
  "compilerOptions": {
    "target": "esnext",
    "jsx": "react-jsx",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": "dist",
    "skipLibCheck": true
  },
  "include": [
    "src",
    "turbo"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
