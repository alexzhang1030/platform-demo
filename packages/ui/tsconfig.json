{
  "compilerOptions": {
    "target": "esnext",
    "jsx": "react-jsx",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@workspace/ui/*": [
        "./src/*"
      ]
    },
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "."
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
